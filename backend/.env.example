# Cayde-6 Environment Configuration

# Core
CAYDE6_ENV=development
CAYDE6_SECRET_KEY=cayde6-dev-secret-key-change-in-production
CAYDE6_API_PORT=8000

# Database (PostgreSQL only)
DATABASE_URL=postgresql+asyncpg://cayde6:cayde6pass@localhost:5432/cayde6

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Redis / Event bus
REDIS_URL=redis://localhost:6379
USE_MEMORY_BUS=true

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# MongoDB Atlas (threat intel hub - optional)
AEGIS_MONGODB_URI=
