# ============================================================
# AEGIS Backend — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# All variables have sensible defaults for local development.
# ============================================================

# --- Core ---
# Environment: development | production
CAYDE6_ENV=development
# Secret key used for internal signing (generate a random 64-char string in production)
CAYDE6_SECRET_KEY=cayde6-dev-secret-key-change-in-production
# Port the API listens on
CAYDE6_API_PORT=8000

# --- Database (PostgreSQL — required) ---
# Format: postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
# Docker Compose auto-sets this; override only for external DB
DATABASE_URL=postgresql+asyncpg://aegis:aegis_secret@localhost:5432/aegis

# --- Redis / Event Bus ---
# Redis URL for pub/sub and caching
REDIS_URL=redis://localhost:6379
# Set to true to use in-memory event bus instead of Redis (dev only)
USE_MEMORY_BUS=true

# --- JWT Authentication ---
# Secret key for signing JWT tokens (generate a random string in production)
JWT_SECRET_KEY=aegis-dev-jwt-secret-change-in-production
# Algorithm: HS256 recommended
JWT_ALGORITHM=HS256
# Token expiry in minutes (1440 = 24 hours)
JWT_EXPIRE_MINUTES=1440

# --- AI Providers ---
# OpenRouter: multi-model routing (recommended)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama: self-hosted local models (optional)
# OLLAMA_BASE_URL=http://localhost:11434

# --- MongoDB Atlas (optional) ---
# --- Community Threat Intelligence Hub ---
# AEGIS instances share anonymized IOCs (IPs, domains, MITRE techniques) via a central hub.
# Two options:
#
# Option 1: MongoDB Atlas (direct DB connection — for self-hosted hubs)
# AEGIS_MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/aegis_community_hub
#
# Option 2: HTTP Hub (connect to another AEGIS instance acting as hub — recommended)
# AEGIS_HUB_URL=https://hub.aegis-defense.io/api/v1/intel
#
# What gets shared: hashed IPs, attack types, MITRE techniques, confidence scores
# What NEVER gets shared: hostnames, internal IPs, user data, configurations
# Leave both empty to run standalone (no community sharing)
AEGIS_MONGODB_URI=
AEGIS_HUB_URL=

# --- Inception Labs (Mercury-2 diffusion LLM, optional) ---
# Free tier: 10M tokens. Fast diffusion-based model with structured output support.
# Get your key at: https://console.inceptionlabs.ai
# INCEPTION_API_KEY=sk_your_key_here

# --- Firewall Integration (optional) ---
# URL of an external firewall API that exposes /block and /unblock endpoints
# Leave empty to use only the built-in local middleware blocking (recommended)
# AEGIS_FIREWALL_URL=http://192.168.1.x:8000

# --- Safe IPs ---
# IPs that should NEVER be blocked by the attack detector (comma-separated)
# The host's own IPs are auto-detected at startup, but add any additional trusted IPs here
# AEGIS_SAFE_IPS=127.0.0.1,::1,localhost,10.0.0.0/8

# --- Platform ---
# Hint for platform-specific behavior: linux | darwin | win32
# AEGIS_PLATFORM=linux
