{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AEGIS Node",
  "version": "0.1.0",
  "identifier": "com.aegis.node",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AEGIS Node",
        "width": 400,
        "height": 580,
        "minWidth": 340,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "decorations": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' http://* https://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
